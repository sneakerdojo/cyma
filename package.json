{
  "name": "octio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.3",
  "workspaces": {
    "packages": ["packages/*"],
    "catalog": {
      "typescript": "~6.0.2",
      "zod": "^4.0.0"
    }
  },
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:web": "bun run --filter @octio/web dev",
    "dev:worker": "bun run --filter @octio/worker dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test"
  }
}
