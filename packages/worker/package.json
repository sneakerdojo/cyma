{
  "name": "@octio/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "get-refresh-token": "bun run scripts/get-refresh-token.ts",
    "create-groups": "bun run scripts/create-groups.ts",
    "setup-team-calendar": "bun run scripts/setup-team-calendar.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/openai-compatible": "2.0.41",
    "@mastra/ai-sdk": "^1.3.3",
    "@mastra/core": "^1.24.1",
    "@mastra/memory": "^1.15.0",
    "@mastra/pg": "^1.9.0",
    "@octio/shared": "workspace:*",
    "ai": "^6.0.158",
    "drizzle-orm": "^0.44.0",
    "googleapis": "^171.4.0",
    "hono": "^4.10.0",
    "node-cron": "^4.2.1",
    "open": "^11.0.0",
    "pino": "^9.0.0",
    "postgres": "^3.4.0",
    "twilio": "^5.13.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node-cron": "^3.0.11",
    "@vitest/ui": "^3.0.0",
    "drizzle-kit": "^0.31.0",
    "pino-pretty": "^11.0.0",
    "typescript": "catalog:",
    "vitest": "^3.0.0"
  }
}
