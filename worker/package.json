{
  "name": "@octio/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file .env src/index.ts",
    "start": "node --env-file .env dist/index.js",
    "build": "tsc && cp -r src/prompts src/knowledge dist/",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "get-refresh-token": "tsx --env-file .env scripts/get-refresh-token.ts",
    "create-groups": "tsx --env-file .env scripts/create-groups.ts",
    "setup-team-calendar": "tsx --env-file .env scripts/setup-team-calendar.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/openai-compatible": "2.0.41",
    "@hono/node-server": "^1.13.0",
    "@mastra/ai-sdk": "^1.3.3",
    "@mastra/core": "^1.24.1",
    "@mastra/memory": "^1.15.0",
    "@mastra/pg": "^1.9.0",
    "@octio/shared": "workspace:*",
    "ai": "^6.0.158",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "googleapis": "^171.4.0",
    "hono": "^4.6.0",
    "node-cron": "^4.2.1",
    "open": "^11.0.0",
    "pino": "^9.0.0",
    "postgres": "^3.4.0",
    "twilio": "^5.13.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/ui": "^2.0.0",
    "drizzle-kit": "^0.28.0",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
