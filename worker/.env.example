# Local dev port 5434 to avoid conflicts with other Postgres instances on 5432.
# On the VPS (gen4) there is no other Postgres so use 5432 in prod .env.
DATABASE_URL=postgres://octio:octio_local_dev@localhost:5434/octio
POSTGRES_PASSWORD=octio_local_dev
# Google OAuth (Step 5 — Task #5)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SENDER_EMAIL=hello@octio.co.za
OCTIO_TEAM_EMAIL=team@octio.co.za
# Google Groups — leads management
LEADS_GROUP_EMAIL=leads@octio.co.za
OUTREACH_GROUP_EMAIL=outreach@octio.co.za
# File storage (Task #8)
UPLOAD_DIR=./uploads
UPLOAD_PUBLIC_URL_BASE=http://localhost:3000/uploads
# LLM provider (kimi | anthropic). Auto-detected from which API key is set if omitted.
# Set LLM_PROVIDER=anthropic to force Anthropic even when KIMI_API_KEY is present.
LLM_PROVIDER=

# Anthropic (Claude) — used if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Moonshot Kimi — used if LLM_PROVIDER=kimi
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2-0905-preview
# Backups (Task #23)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
BACKUP_ENCRYPTION_KEY=
